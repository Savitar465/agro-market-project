# ----------------------------------------------------------------------------
# Frontend environment variables (Next.js)
#
# Copy this file to `.env.local` and fill in the values:
#   cp .env.example .env.local
#
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# ----------------------------------------------------------------------------

# Base URL of the backend API.
# Local development default is http://localhost:3001.
# In production set this to your deployed backend, e.g. https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional static API token used for server-side requests when no user is
# logged in. Leave empty in normal use — authenticated requests use the JWT
# stored in localStorage after login. Not recommended for production.
NEXT_PUBLIC_API_TOKEN=
